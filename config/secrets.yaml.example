homeassistant:
  token: "DEIN_HA_LONG_LIVED_TOKEN_HIER"

# Web-Admin-Passwort NICHT hier im Klartext ablegen. Es wird als scrypt-Hash in
# config/webconfig.yaml gesetzt – per scripts/set_web_password.py, in der Web-UI
# (Einstellungen -> Admin-Passwort) oder automatisch beim ersten Start
# (Zufallspasswort in data/initial-web-password.txt).

storage:
  # At-Rest-Verschluesselung fuer private Nachrichten (msg_type='P'), AES-256-GCM.
  # Erzeugen mit: python -c "from core.crypto import generate_key; print(generate_key())"
  # Ohne diesen Key werden private Nachrichten unverschluesselt gespeichert (Warnung im Log).
  # Bei Verlust dieses Keys sind bereits gespeicherte private Nachrichten nicht mehr lesbar!
  messages_key: "HIER_GENERIERTEN_BASE64_KEY_EINFUEGEN"
